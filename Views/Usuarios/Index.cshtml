@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery
@{
    ViewData["Title"] = "Listado de Usuarios";
    Layout = "~/Views/Shared/AdminLTE/_Layout.cshtml";
    var tokenSet = antiforgery.GetAndStoreTokens(Context);
}


<section class="content-header">

    <div class="row">

        <div class="col-md-12">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <b>Listado de Usuarios </b>

                    <div class="card-tools">
                        <a class="btn btn-tool" title="Nuevo" asp-action="Create">NUEVO</a>
                        <a class="btn btn-tool" title="Ir al Inicio" asp-area="" asp-controller="Home" asp-action="Index">  <i class="nav-icon fas fa-home"></i></a>
                        <a class="btn btn-tool" title="Atras" onclick="history.go(-1); return false;" href="#">  <i class="fas fa-arrow-alt-circle-left"></i></a>
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-minus"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body ">
                    <div class="row">
                        <div class="card-body table-responsive p-2 text-sm">
                            <table class="table table-sm table-hover text-nowrap w-100" id="tabla"></table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</section>

<script>
    $(function () {

        $("#tabla").DataTable({
            processing: true,
            serverSide: true,
            deferRender: true,
            responsive: true,
            paging: true,
            lengthChange: true,
            searching: false,
            ordering: true,
            info: true,
            lengthMenu: [10, 50, 100, 200, 500, 1000],
            dom: 'Blfrtip',
            buttons: [
                {
                    extend: 'collection',
                    autoClose: 'true',

                    text: '',
                    tag: 'span',
                    buttons: [

                        { extend: 'excel', text: 'Excel', filename: 'Export_' + '@Html.Raw(ViewData["Title"])' },
                        { extend: 'pdf', text: 'PDF', filename: 'Export_' + "'" + '@Html.Raw(ViewData["Title"])' },
                        { extend: 'colvis', text: 'Columnas Ver / Ocultar' }
                    ]
                }
            ],
            ajax: {
                url: '@Url.Action("GetIndex")',
                type: "POST",
                datatype: "json",
                headers: {
                    '@tokenSet.HeaderName': '@tokenSet.RequestToken'
                },
                data: function (d) {

                    //var filtro = [{ key: 'descripcion', value: $('#txtParam').val() },
                    //{ key: 'parametricosHeaderId', value: $('#cboParametricosHeaderId').val() },
                    //];

                    //d.param = JSON.stringify(filtro);
                },
                dataSrc: function (resp) {
                    return resp.data;
                },

                error: function handleAjaxError(xhr, textStatus, error) {

                    $(".dataTables_processing").hide();
                }
            },
            columns: [
                { data: "nombre", "title": "Nombre", "name": "nombre", "defaultContent": "" },
                { data: "correo", "title": "Correo", "name": "correo", "defaultContent": "" },
                {
                    data: "id", "width": 2, "orderable": false,
                    render: function (data, row) {
                        var hrefEdit = '@Url.Content("~/Usuarios/Edit/")' + data;
                        var icoEdit =  '<a href="' + hrefEdit + '" title="Modificar"><i class="far fa-edit text-success"></i></a>';

                        var hrefPass = '@Url.Content("~/Account/ClaveReset/")' + data;
                        var icoPass = '<a href="' + hrefPass + '" title="Cambiar Clave al Usuario"><i class="fas fa-key text-yellow"></i></a>';

                        return icoEdit + ' ' + icoPass;
                    }
                }
            ],
            createdRow: function (row, data) {
                if (data.baja == true) {
                    $(row).addClass('bg-danger disabled color-palette');
                }
            },
            language: {
                url: '@Url.Content("~/plugins/datatables/idioma.json")'
            }
        });

    });
</script>