@model Tracker.DTOs.ChoferDTO
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery
@{
    var tokenSet = antiforgery.GetAndStoreTokens(Context);
}

<section class="content-header">
    <div class="col-md-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <b> Choferes </b>
                <div class="card-tools">
                    <a class="btn btn-tool" title="Ir al Inicio" asp-area="" asp-controller="Home" asp-action="Index">  <i class="nav-icon fas fa-home"></i></a>
                    <a class="btn btn-tool" title="Atras" onclick="history.go(-1); return false;" href="#">  <i class="fas fa-arrow-alt-circle-left"></i></a>

                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body ">
                <form id="frmChofer">
                    
                    <div class="row">
                        <div class="form-group col-md-6 col-xs-12 ">
                            <label asp-for="ApellidoNombre" class="control-label"></label>
                            <input asp-for="ApellidoNombre" class="form-control" autofocus required />
                            <span asp-validation-for="ApellidoNombre" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-2  col-xs-12">
                            <label asp-for="Dni" class="control-label"></label>
                            <input asp-for="Dni" class="form-control" required />
                            <span asp-validation-for="Dni" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-2  col-xs-12">
                            <label asp-for="Legajo" class="control-label"></label>
                            <input asp-for="Legajo" class="form-control" required />
                            <span asp-validation-for="Legajo" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-2  col-xs-12">
                            <label asp-for="Telefono" class="control-label"></label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col-md-10  col-xs-12">
                            <label asp-for="Observacion" class="control-label"></label>
                            <input asp-for="Observacion" class="form-control" spellcheck="true"  />
                            <span asp-validation-for="Observacion" class="text-danger"></span>
                            
                        </div>
                    </div>
                    <div class="card-footer ">
                        <div class="float-left">
                        </div>
                        <div class="float-right">
                            <button id="btnAceptar" type="button"  value="Aceptar" class="btn btn-success"> <i class="far fa-save"></i> Guardar </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script type="text/javascript">

    $(document).ready(function () {


     setTimeout(function() {
            $('#RazonSocial').focus();
    }, 500);

        $("#btnAceptar").click(function (e) {
            e.preventDefault();
            if (!$("#frmChofer").valid())
                return;

            var boton = this;
            disableButtonOnClick(boton);

            $.ajax({
                type: "POST",
                url: '@Url.Action("Create")',
                dataType: "json",
                headers: {
                    '@tokenSet.HeaderName': '@tokenSet.RequestToken'
                },
                data: $('#frmChofer').serialize() + "&returnUrl=js",
                success: function (data) {

                    enabledButtonOnClick(boton);

                    viewMessage(data);

                    if (data.status === 0 || data.status === "OK") {

                        var choferFromBBDD = JSON.stringify(data.tagObj);
                        choferGrabado(choferFromBBDD); //es el evento para que sepa la pantalla de envios que tiene que cerrarse
                    }
                },
                error: function (e) {
                    enabledButtonOnClick(boton);
                    toastr.error(e.responseText);
                }
            });
        });
    })

</script>