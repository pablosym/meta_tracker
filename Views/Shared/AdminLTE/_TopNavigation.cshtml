@inject IConfiguration Configuration
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var nombreUsuario = User?.Identity?.Name ?? "";

}
<nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <!-- Left navbar links -->
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">INICIO</a>

        </li>
        <li class="nav-item d-none d-sm-inline-block">

            @if (Configuration.GetSection("EntornoQA")?.Value == "True")
            {
                <p class="blink nav-link text-red" title="Este es un entorno de pruebas. Por favor, no lo utilice para fines de producción.">ENTORNO DE PRUEBAS</p>
            }
        </li>
    </ul>


    <ul class="navbar-nav ml-auto">
        @if (!isAuthenticated)
        {
            <li class="nav-item dropdown user-menu">
                <a asp-controller="Account" asp-action="Login" class="nav-link dropdown-toggle"><img src="~/img/LoginIconOut.png" class="user-image img-circle elevation-2" alt="User Image"></a>
            </li>
        }

        @if (isAuthenticated)
        {
            <!-- Notifications  Dropdown Menu-->
            <li class='nav-item dropdown'>
                <div id="divNotificaciones"></div>
            </li>

            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">
                    <img src="~/img/LoginIconIn.png" class="user-image img-circle elevation-2" alt="User Image">
                    <span class="d-none d-md-inline">  @nombreUsuario</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-right">

                    <li class="user-header bg-primary">
                        <img src="~/img/LoginIconIn.png" class="img-circle elevation-2" alt="User Image">
                        <p>@nombreUsuario</p>
                    </li>

                    <li class="user-body">
                        <div class="row">

                            <a asp-controller="Account" asp-action="Clave" class="btn btn-primary text-sm ">Cambiar Clave</a>

                        </div>

                    </li>

                    <li class="user-footer">
                        <div class="float-right">


                            <form id='frmLogout' name='frmLogout' class="form-inline" asp-controller="Account" asp-action="Logout">
                                <a asp-controller="Account" asp-action="Logout" class="btn btn-primary float-right">Salir</a>
                            </form>
                        </div>
                    </li>
                </ul>
            </li>
        }
    </ul>
</nav>

